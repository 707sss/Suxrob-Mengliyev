  }

  #stars-canvas {
    position: fixed;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .page {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 13px;
  }

  /* ── Avatar ── */
  .ava-wrap {
    position: relative;
    width: 120px; height: 120px;
    margin-bottom: 8px;
  }
  .ava-spin {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    padding: 2px;
    background: conic-gradient(
      from 0deg,
      #7c3aed 0%, #a855f7 15%, #ec4899 30%,
      #f43f5e 45%, #f97316 55%, #22c55e 70%,
      #06b6d4 82%, #3b82f6 92%, #7c3aed 100%
    );
    animation: rotateSpin 5s linear infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }
  @keyframes rotateSpin { to { transform: rotate(360deg); } }
  .ava-photo {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    overflow: hidden;
    background: #050508;
  }
  .ava-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 18%;
    transform: scale(1.55);
    transform-origin: center 30%;
  }

  .name {
    font-size: 21px;
    font-weight: 700;
    color: #fff;
    text-align: center;
    letter-spacing: -0.2px;
  }
  .handle {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    text-align: center;
    margin-top: -4px;
  }

  /* ── Glass card (full width) ── */
  .card {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 18px;
    padding: 13px 18px;
    display: flex;
    align-items: center;
    gap: 13px;
    text-decoration: none;
    color: #fff;
    transition: background .18s, transform .14s, border-color .18s;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .card:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.16);
    transform: translateY(-2px);
  }
  .card:active { transform: scale(0.975); }

  .ico {
    width: 44px; height: 44px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .ico img { width: 100%; height: 100%; object-fit: cover; }

  .card-body { flex: 1; min-width: 0; }
  .card-title { font-size: 14.5px; font-weight: 600; }
  .card-sub   { font-size: 11.5px; color: rgba(255,255,255,0.4); margin-top: 2px; }
  .card-arr   { color: rgba(255,255,255,0.25); font-size: 18px; flex-shrink: 0; }

  /* ── 2-col grid ── */
  .two-col {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 11px;
  }
  .mini-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 18px;
    padding: 18px 10px 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: #fff;
    transition: background .18s, transform .14s, border-color .18s;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .mini-card:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(255,255,255,0.16);
    transform: translateY(-2px);
  }
  .mini-card:active { transform: scale(0.970); }

  .mini-ico {
    width: 48px; height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  .mini-ico img { width: 100%; height: 100%; object-fit: cover; }

  .mini-title { font-size: 12px; font-weight: 600; text-align: center; line-height: 1.3; }
  .mini-sub   { font-size: 11px; color: rgba(255,255,255,0.36); text-align: center; }
</style>
